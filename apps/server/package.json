{
    "name": "@smart/server",
    "version": "0.0.0",
    "private": true,
    "scripts": {
        "build": "nest build",
        "dev": "nest start --watch",
        "start": "nest start",
        "lint": "eslint \"{src,test}/**/*.ts\" --fix",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "migration:run": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:run -d src/database/data-source.ts",
        "migration:revert": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:revert -d src/database/data-source.ts",
        "seed": "ts-node -r tsconfig-paths/register src/database/seed.ts"
    },
    "dependencies": {
        "@nestjs/common": "^10.4.0",
        "@nestjs/core": "^10.4.0",
        "@nestjs/jwt": "^10.2.0",
        "@nestjs/passport": "^10.0.3",
        "@nestjs/platform-express": "^10.4.0",
        "@nestjs/platform-ws": "^10.4.0",
        "@nestjs/throttler": "^6.2.0",
        "@nestjs/typeorm": "^10.0.2",
        "@nestjs/websockets": "^10.4.0",
        "bcryptjs": "^2.4.3",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.1",
        "dotenv": "^17.4.2",
        "helmet": "^8.0.0",
        "passport": "^0.7.0",
        "passport-jwt": "^4.0.1",
        "passport-local": "^1.0.0",
        "pg": "^8.13.0",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.1",
        "typeorm": "^0.3.20",
        "uuid": "^10.0.0",
        "ws": "^8.18.0",
        "zod": "^3.23.0"
    },
    "devDependencies": {
        "@nestjs/cli": "^10.4.0",
        "@nestjs/schematics": "^10.1.0",
        "@nestjs/testing": "^10.4.0",
        "@types/bcryptjs": "^2.4.6",
        "@types/express": "^5.0.0",
        "@types/node": "^22.0.0",
        "@types/passport-jwt": "^4.0.1",
        "@types/passport-local": "^1.0.38",
        "@types/uuid": "^10.0.0",
        "@types/ws": "^8.5.0",
        "ts-node": "^10.9.2",
        "typescript": "^5.7.0",
        "vitest": "^2.1.0"
    }
}